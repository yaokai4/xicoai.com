# Automatic HTTPS via Let's Encrypt. DNS for both names must point at
# this host, and inbound 80/443 must be open in the firewall/SG.
{
	email hi@xicoai.com
}

xicoai.com {
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
	reverse_proxy app:3000
}

www.xicoai.com {
	redir https://xicoai.com{uri} permanent
}

# Xico Clean product site. Needs a DNS A record: mac.xicoai.com → this host.
# The app's proxy.ts rewrites this host's "/" to the /mac product route.
mac.xicoai.com {
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
	reverse_proxy app:3000
}

# Mail host: Caddy owns 80/443 and is a reliable ACME client, so it issues &
# auto-renews the Let's Encrypt cert for mail.xicoai.com here. Stalwart's own
# ACME is stuck (after its first tls-alpn-01 attempt failed — 443 is taken by
# Caddy — it never re-attempts), so deploy/sync-mail-cert.sh (a systemd timer)
# copies Caddy's cert into Stalwart for its IMAP/SMTP TLS listeners.
# Caddy also reverse-proxies to Stalwart's built-in web Portal at mail.xicoai.com
# (webmail + account self-service + admin management console). WebSocket (JMAP
# push) is upgraded automatically by reverse_proxy.
mail.xicoai.com {
	reverse_proxy xicoai-stalwart:8080
}
