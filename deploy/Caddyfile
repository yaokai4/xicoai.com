# Automatic HTTPS via Let's Encrypt. DNS for both names must point at
# this host, and inbound 80/443 must be open in the firewall/SG.
{
	email hi@xicoai.com
}

xicoai.com {
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
	reverse_proxy app:3000
}

www.xicoai.com {
	redir https://xicoai.com{uri} permanent
}

# Xico Clean product site. Needs a DNS A record: mac.xicoai.com → this host.
# The app's proxy.ts rewrites this host's "/" to the /mac product route.
mac.xicoai.com {
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
	reverse_proxy app:3000
}

# Mail host: only Let's Encrypt HTTP-01 challenges are exposed (Stalwart's
# ACME obtains certs for IMAP/SMTP TLS through here). Everything else on the
# mail hostname bounces to the main site; the mail admin API stays internal.
http://mail.xicoai.com {
	handle /.well-known/acme-challenge/* {
		reverse_proxy xicoai-stalwart:8080
	}
	handle {
		redir https://xicoai.com{uri} permanent
	}
}
