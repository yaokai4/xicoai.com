# ── Database ───────────────────────────────────────────────
# PostgreSQL connection string (no SQLite). On the server this points
# at the Postgres docker container; locally at a dev Postgres.
DATABASE_URL=postgres://xico:xico@localhost:5432/xico

# ── Admin console (/admin) ─────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-long-random-string
# Secret used to sign the admin session cookie (32+ random chars)
AUTH_SECRET=change-this-to-a-long-random-secret

# ── Mail system (self-hosted engine in ./mailer) ───────────
# OUTBOUND: every message is queued in Postgres (mail_outbox) and sent by the
# mailer container. Two transports:
#   relay  (default) — authenticated SMTP below (Aliyun: From must equal
#                      SMTP_USER). Works today; just fill SMTP_PASS.
#   direct           — per-domain MX + port 25 push with DKIM. Needs AWS to
#                      unblock outbound port 25 first, then:
#                      node scripts/gen-dkim.mjs → publish TXT → MAIL_DKIM=1.
MAIL_TRANSPORT=relay
SMTP_HOST=smtp.qiye.aliyun.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=hi@xicoai.com
SMTP_PASS=
# Marketing blast throttle (messages/minute):
MAIL_RATE_PER_MIN=30
# INBOUND: catch-all for these domains (unlimited addresses). Requires DNS MX
# → this host and TCP 25 open in the Lightsail firewall.
MAIL_DOMAINS=xicoai.com,mac.xicoai.com
MAIL_HELO=mail.xicoai.com
# Direct-mode sender identity + optional DKIM:
MAIL_FROM=hi@xicoai.com
MAIL_FROM_NAME=Xico Clean
MAIL_DKIM=0
MAIL_DKIM_SELECTOR=xico
# Where internal notifications are delivered:
NOTIFY_TO=hi@xicoai.com

# ── Uploads ────────────────────────────────────────────────
# Directory for uploaded résumés (mounted volume in production).
UPLOAD_DIR=./uploads

# ── Public site URL ────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://xicoai.com
# Product domain (used in the activation-key email):
NEXT_PUBLIC_MAC_URL=https://mac.xicoai.com

# ── Xico Clean commerce (Stripe + activation keys) ─────────
# Reuses the SAME Stripe account as Shangence. Register a DEDICATED webhook
# endpoint (its own signing secret) at:  https://mac.xicoai.com/api/webhooks/stripe
# and subscribe it to: checkout.session.completed, checkout.session.expired
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Optional (publishable key is not required — Checkout is hosted by Stripe):
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Pepper for hashing/encrypting the 18-digit activation keys at rest.
# 24+ chars. NEVER change once keys have been issued (orphans every key).
LICENSE_KEY_SECRET=change-this-to-a-long-random-secret-32chars+

# Ed25519 license signing. Generate with:  node scripts/gen-license-keypair.mjs
# The private key stays here (server-only); its public half is baked into the
# Mac app's Info.plist (make_app.sh XICO_LICENSE_PUBLIC_KEYS) under the same keyID.
XICO_LICENSE_KEY_ID=xico-license-1
XICO_LICENSE_PRIVATE_KEY=base64-raw-32-byte-ed25519-seed
# Optional: override the productID embedded in licenses (must match the app):
# XICO_LICENSE_PRODUCT_ID=com.xico.app
