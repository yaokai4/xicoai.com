# ── Database ───────────────────────────────────────────────
# PostgreSQL connection string (no SQLite). On the server this points
# at the Postgres docker container; locally at a dev Postgres.
DATABASE_URL=postgres://xico:xico@localhost:5432/xico

# ── Admin console (/admin) ─────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-long-random-string
# Secret used to sign the admin session cookie (32+ random chars)
AUTH_SECRET=change-this-to-a-long-random-secret

# ── Transactional email (Aliyun enterprise mail) ───────────
# Leave SMTP_* empty to disable sending; submissions are still stored.
SMTP_HOST=smtp.qiye.aliyun.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=hi@xicoai.com
SMTP_PASS=
# Where internal notifications are delivered:
NOTIFY_TO=hi@xicoai.com

# ── Uploads ────────────────────────────────────────────────
# Directory for uploaded résumés (mounted volume in production).
UPLOAD_DIR=./uploads

# ── Public site URL ────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://xicoai.com
